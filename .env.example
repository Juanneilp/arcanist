# ==========================================
# FILE CONTOH / TEMPLATE ENVIRONMENT (.env.example)
# ==========================================
# File ini digunakan sebagai template. Anda harus meng-copy file ini
# menjadi file bernama `.env` dan mengisi nilainya dengan data Anda sendiri.
# File `.env` SANGAT RAHASIA dan tidak boleh di-commit ke Git.

# Kredensial GMGN API (Wajib untuk pengambilan data chart/market)
# Anda bisa mendapatkannya di https://gmgn.ai/ai
GMGN_API_KEY=gmgn_solbscbaseethmonadtron

# Solana RPC URL (Wajib)
# Digunakan untuk transaksi di jaringan Solana. Helius sangat disarankan.
RPC_URL=https://api.mainnet-beta.solana.com

# Private Key Dompet Solana (Wajib)
# Diisikan dengan format string Base58.
# [PERINGATAN] Siapa pun yang memiliki akses ke private key ini memiliki akses penuh ke dana Anda.
WALLET_PRIVATE_KEY=your_base58_private_key_here

# Konfigurasi Akses AI (Wajib)
# Nilai di sini adalah kunci rahasia (API Key) dan diprioritaskan melebihi user-config.json.
# AI_BASE_URL dan AI_MODEL bisa ditempatkan di user-config.json, tapi API Key WAJIB di sini.
AI_API_KEY=your_ai_provider_api_key
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=nousresearch/hermes-3-llama-3.1-405b

# Konfigurasi Telegram Bot (Opsional)
# Digunakan untuk mengirimkan sinyal entri/keluar dan laporan ke Telegram Anda.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ==========================================
# Konfigurasi Lanjutan GMGN (Opsional/Khusus)
# ==========================================
# [SECURITY WARNING] GMGN_PRIVATE_KEY adalah kunci penandatanganan request (bukan dompet).
# Digunakan untuk mengotentikasi request API swap GMGN (jika digunakan).
GMGN_PRIVATE_KEY=

#JUPITER API KEY
JUPITER_API_KEY=
